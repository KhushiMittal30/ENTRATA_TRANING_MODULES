<?xml version="1.0" encoding="UTF-8"?>
<!-- colors="true" Enable colored output in the terminal 
         stopOnFailure="false" Continue running tests even if one fails 
         stopOnError="false" Continue running tests even if an error occurs
         verbose="true" Enable verbose output for more detailed test results
-->
<phpunit bootstrap="vendor/autoload.php"
         colors="true" 
         stopOnFailure="false" 
         stopOnError="false"   
         verbose="true">
    <testsuites>
        <testsuite name="Calculator">
            <directory>tests</directory>
        </testsuite>
        <!-- <testsuite name="Feature Tests">
            <directory>./tests/Feature</directory>
        </testsuite> -->
    </testsuites>

